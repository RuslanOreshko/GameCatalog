@model GameCatalog.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="section-card" style="max-width: 700px; margin: 0 auto;">
<h1 class="mb-4">Login</h1>

<form asp-action="Login" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="UsernameOrEmail" class="form-label"></label>
        <input asp-for="UsernameOrEmail" class="form-control" />
        <span asp-validation-for="UsernameOrEmail" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Login</button>
</form>
</dir>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}