@model List<GameCatalog.ViewModels.Genres.GenreAdminListItemViewModel>

@{
    ViewData["Title"] = "Manage Genres";
}


<div class="section-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Genres</h1>
        <a asp-controller="Admin" asp-action="CreateGenre" class="btn btn-success">Create Genre</a>
    </div>

    @if (TempData["GenreError"] is not null)
    {
        <div class="alert alert-danger">
            @TempData["GenreError"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">No genres found.</div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Games Count</th>
                    <th style="width: 220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var genre in Model)
                {
                    <tr>
                        <td>@genre.Name</td>
                        <td>@genre.Description</td>
                        <td>@genre.GamesCount</td>
                        <td>
                            <a asp-controller="Admin" asp-action="EditGenre" asp-route-id="@genre.Id" class="btn btn-primary btn-sm">
                                Edit
                            </a>

                            <form asp-controller="Admin" asp-action="DeleteGenre" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@genre.Id" />
                                <button type="submit" class="btn btn-danger btn-sm"
                                        onclick="return confirm('Delete this genre?');">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>