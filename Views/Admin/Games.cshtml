@model List<GameCatalog.ViewModels.Games.GameAdminListItemViewModel>

@{
    ViewData["Title"] = "Manage Games";
}

<div class="section-card">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Manage Games</h1>
        <a asp-controller="Admin" asp-action="CreateGame" class="btn custom-btn-primary">
            Create Game
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No games found.</div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Genre</th>
                    <th>Developer</th>
                    <th>Release Date</th>
                    <th>Rating</th>
                    <th style="width: 220px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var game in Model)
                {
                    <tr>
                        <td>@game.Title</td>
                        <td>@game.GenreName</td>
                        <td>@game.Developer</td>
                        <td>@game.ReleaseDate.ToString("dd.MM.yyyy")</td>
                        <td>@game.Rating</td>
                        <td>
                            <a asp-controller="Admin"
                               asp-action="EditGame"
                               asp-route-id="@game.Id"
                               class="btn custom-btn-primary btn-sm me-2">
                                Edit
                            </a>

                            <form asp-controller="Admin"
                                  asp-action="DeleteGame"
                                  method="post"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@game.Id" />

                                <button type="submit"
                                        class="btn custom-btn-danger btn-sm"
                                        onclick="return confirm('Delete this game?');">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>